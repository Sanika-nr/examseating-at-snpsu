cat > /home/claude/exam_seating_project/backend/.env << 'EOF'
PORT=3308
DB_HOST=localhost
DB_USER=root
DB_PASS=your_mysql_password
DB_NAME=exam_seating_db
JWT_SECRET=surana_exam_secret_key_2024_change_in_production

# ── EMAIL CONFIG (Gmail SMTP) ──────────────────────────────────────
# Step 1: Go to https://myaccount.google.com/security
# Step 2: Enable 2-Step Verification
# Step 3: Search "App Passwords" → Generate one for "Mail"
# Step 4: Paste the 16-char app password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_college_email@gmail.com
SMTP_PASS=your_16char_app_password
SMTP_FROM=ExamSeat Surana College <your_college_email@gmail.com>

OTP_EXPIRY_MINUTES=10
EOF
echo "done"